rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isOwner() {
      return request.auth != null && request.auth.token.email == 'wramkim@gmail.com';
    }

    function isPublishedLetter() {
      return resource.data.visibility in ['public', 'link-only'];
    }

    match /letters/{letterId} {
      // 링크를 받은 사람은 해당 문서 1개만 get 가능. 목록(list/query)은 형님만 가능.
      allow get: if isOwner() || isPublishedLetter();
      allow list: if isOwner();
      allow create, update, delete: if isOwner();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
