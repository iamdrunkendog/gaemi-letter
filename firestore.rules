rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isOwner() {
      return request.auth != null && request.auth.token.email == 'wramkim@gmail.com';
    }

    function isShareableLetter() {
      return resource.data.visibility in ['public', 'link-only', 'password'];
    }

    match /letters/{letterId} {
      // public/link-only: 링크 소지자 공개. password: 암호화된 문서만 공개 get, 복호화는 브라우저에서 비밀번호로 수행.
      // private: 관리자만 get 가능.
      allow get: if isOwner() || isShareableLetter();
      allow list: if isOwner();
      allow create, update, delete: if isOwner();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
